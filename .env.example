# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Weights & Biases — get from https://wandb.ai/authorize
WANDB_API_KEY=

# Hugging Face — get from https://huggingface.co/settings/tokens (needs WRITE)
HF_TOKEN=

# GitHub PAT used by the pod to `git clone` the repo. Needs only `repo:read`.
# Create at https://github.com/settings/tokens
GITHUB_TOKEN=
